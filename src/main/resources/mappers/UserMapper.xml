<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

    <mapper namespace="com.complanint.Repository.UserRepo">

    <select id="findById" parameterType="string" resultType="com.complanint.Entity.User">
        select * from user2 where userId=#{userId}


    </select>



    <insert id="save" >
        insert into user2 ( userId, password, name, tel, email , role)
        values( #{userId}, #{password}, #{name}, #{tel}, #{email}, #{role})

    </insert>


</mapper>
